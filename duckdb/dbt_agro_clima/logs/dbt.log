[0m12:33:01.652308 [debug] [Thread-1 (]: On model.dbt_agro_clima.int_mercado_enriquecido: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "dbt_agro_clima", "target_name": "dev", "node_id": "model.dbt_agro_clima.int_mercado_enriquecido"} */

  
  create view "dev"."main"."int_mercado_enriquecido__dbt_tmp" as (
    with base as (

    select * from "dev"."main"."stg_mercado"

),

final as (

    select
        data,
        ticker,
        preco_abertura,
        preco_maximo,
        preco_minimo,
        preco_fechamento,
        volume,

        (
            preco_fechamento
            - lag(preco_fechamento) over (
                partition by ticker
                order by data
            )
        )
        / nullif(
            lag(preco_fechamento) over (
                partition by ticker
                order by data
            ),
            0
        ) as retorno_diario,

        avg(preco_fechamento) over (
            partition by ticker
            order by data
            rows between 6 preceding and current row
        ) as media_movel_7d

    from base

)

select * from final
  );

